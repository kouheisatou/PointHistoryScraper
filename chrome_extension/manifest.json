{
	"manifest_version": 3,
	"name": "楽天ポイント履歴一括保存",
	"version": "2.1.1",
	"description": "楽天PointClubのポイント履歴をローカル保存し、期間指定でCSVエクスポート",
	"action": {
		"default_title": "楽天ポイント履歴一括保存"
	},
	"background": {
		"service_worker": "background.js"
	},
	"permissions": [
		"storage",
		"sidePanel"
	],
	"side_panel": {
		"default_path": "sidepanel.html"
	},
	"content_scripts": [
		{
			"matches": [
				"https://point.rakuten.co.jp/history/*"
			],
			"js": [
				"content.js"
			]
		}
	],
	"icons": {
		"128": "icon.png"
	}
}
